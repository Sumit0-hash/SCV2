# Gemini API (server-side)
# Get your key from: https://aistudio.google.com/app/apikey
# Used for: Resume Intelligence, Interview Q&A, and AI Mock Test features
GEMINI_API_KEY=your_gemini_api_key_here

# JSearch API (client-side)
# Get your key from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
VITE_JSEARCH_API_KEY=your_jsearch_api_key_here

# Supabase (server-side)
# Database URL and service role key for mock test storage
# These are automatically configured in the Supabase environment
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Session secret (server-side)
# Generate a random string for production use
SESSION_SECRET=your_session_secret_here
